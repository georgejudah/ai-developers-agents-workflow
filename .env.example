# ===== LLM Configuration =====
# Choose your LLM provider: "ollama" (local) or "openrouter" (API)
LLM_PROVIDER=ollama

# Model to use (depends on provider)
# For Ollama (local):
#   - qwen2.5-coder:7b (fast, good quality, 5-6GB RAM)
#   - qwen2.5-coder:14b (slower, better quality, 10GB RAM)
#   - deepseek-coder-v2:16b (excellent quality, 12GB RAM)
#   - qwen2.5-coder:32b (best quality, 24GB RAM, slower)
# For OpenRouter (API):
#   - deepseek/deepseek-v4-flash (high quality, $0.14/M tokens)
#   - deepseek/deepseek-coder (good quality, cheaper)
LLM_MODEL=qwen2.5-coder:7b

# ===== OpenRouter API (only needed if LLM_PROVIDER=openrouter) =====
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ===== Supabase Database =====
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# ===== GitHub Integration =====
GITHUB_PAT=your_github_personal_access_token

# ===== Observability - Langfuse =====
# Get your keys from https://cloud.langfuse.com (free tier available)
# Leave empty to disable observability
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# ===== Logging Configuration =====
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
